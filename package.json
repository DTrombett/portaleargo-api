{
	"name": "portaleargo-api",
	"version": "1.0.0",
	"description": "A library to interact with the api of ArgoScuolaNext",
	"exports": {
		"./web": "./dist/web.js",
		".": "./dist/index.js"
	},
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"scripts": {
		"build": "node esbuild.ts && tsc",
		"lint": "eslint src --fix",
		"prettier": "prettier --write src/**/*.ts",
		"test": "npm run test:cli && cross-env NODE_ENV=development node esbuild.ts && node --enable-source-maps dist/_test.js",
		"test:cli": "eslint src && tsc --noEmit"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/DTrombett/portaleargo-api.git"
	},
	"author": "DTrombett",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/DTrombett/portaleargo-api/issues"
	},
	"homepage": "https://github.com/DTrombett/portaleargo-api#readme",
	"engines": {
		"node": ">=20"
	},
	"dependencies": {
		"http-cookie-agent": "^7.0.3",
		"tough-cookie": "^6.0.0",
		"undici": "^7.22.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@tsconfig/node20": "^20.1.9",
		"@tsconfig/recommended": "^1.0.13",
		"@tsconfig/strictest": "^2.0.8",
		"@types/node": "^20.19.33",
		"cross-env": "^10.1.0",
		"dotenv": "^17.3.1",
		"esbuild": "^0.27.3",
		"eslint": "^10.0.0",
		"eslint-plugin-node": "^11.1.0",
		"prettier": "^3.8.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.0"
	},
	"optionalDependencies": {
		"ajv": "^8.18.0"
	}
}
